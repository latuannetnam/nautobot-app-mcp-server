# =============================================================================
# Nautobot Import Env Template
# Copy this file to nautobot_import.env and fill in your values.
# nautobot_import.env is gitignored — DO NOT commit it!
# =============================================================================

# --- Production Nautobot Server ---
NAUTOBOT_PROD_URL=https://nautobot.example.com
NAUTOBOT_PROD_TOKEN=nbapikey_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Dev Nautobot Server ---
# URL of the local dev stack (default: http://localhost:8080)
NAUTOBOT_DEV_URL=http://localhost:8080

# Dev superuser API token (from development/creds.env: NAUTOBOT_SUPERUSER_API_TOKEN)
NAUTOBOT_DEV_TOKEN=xxxxxx

# --- Import Scope ---
# Comma-separated list of device names to import (must match exactly)
# Leave empty to import ALL devices
DEVICE_NAMES=device-01,device-02,device-03

# Dry run: set to true to preview what would be imported without writing to dev DB
DRY_RUN=false
